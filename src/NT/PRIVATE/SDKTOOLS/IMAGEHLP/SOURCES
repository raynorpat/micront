MAJORCOMP=sdktools
MINORCOMP=imagehlp

TARGETNAME=imagehlp
TARGETPATH=$(BASEDIR)\public\sdk\lib
TARGETTYPE=DYNLINK
TARGETLIBS=obj\*\imagehlp.res

LINKLIBS=$(BASEDIR)\public\sdk\lib\*\libc.lib \
         $(BASEDIR)\public\sdk\lib\*\kernel32.lib

INCLUDES=$(BASEDIR)\private\ntos\inc

SOURCES=bindi.c       \
        checksum.c    \
        debug.c       \
        map.c         \
        rebasei.c     \
        undecsym.cxx  \
        walk.c        \
        walkx86.c     \
        walkmip.c     \
        walkalp.c

UMAPPL=bind*binplace*checkfix*dbgdump*imagechk*rebase*smashlck*splitsym*undname*verfix*editsym*stripcv

UMTYPE=console
UMRES=$(@R).res
# MicroNT: dropped setargv.obj from upstream UMLIBS.  It hooks the CRT
# argv setup to do shell-glob expansion (so `splitsym *.exe` expands
# client-side), but we only ever invoke these tools with fully-resolved
# per-file paths from build.lua, so it's dead weight here and a
# bootstrap dep we'd otherwise have to track.
UMLIBS=$(BASEDIR)\public\sdk\lib\*\imagehlp.lib \
       $(BASEDIR)\public\sdk\lib\*\libc.lib \
       $(BASEDIR)\public\sdk\lib\*\kernel32.lib \
       $(BASEDIR)\public\sdk\lib\*\ntdll.lib

NTTARGETFILE0=obj\*\bind.res     \
              obj\*\binplace.res \
              obj\*\checkfix.res \
              obj\*\dbgdump.res  \
              obj\*\editsym.res  \
              obj\*\imagechk.res \
              obj\*\imagehlp.res \
              obj\*\rebase.res   \
              obj\*\smashlck.res \
              obj\*\splitsym.res \
              obj\*\stripcv.res  \
              obj\*\undname.res  \
              obj\*\verfix.res


C_DEFINES=$(C_DEFINES) -D_PORTABLE_32BIT_CONTEXT
