MAJORCOMP=sdk
MINORCOMP=resources

TARGETNAME=rcdll
TARGETPATH=obj
TARGETTYPE=DYNLINK
# MicroNT: dropped advapi32.lib from upstream TARGETLIBS — RCDLL has
# no advapi32 call sites (verified: no Reg*, Crypt*, IsTextUnicode,
# etc.).  The lib was a stale upstream dependency.
TARGETLIBS=$(BASEDIR)\public\sdk\lib\*\kernel32.lib

DLLBASE=0x40000000
DLLENTRY=LibMain
USE_CRTDLL=1

PRECOMPILED_CXX=1
PRECOMPILED_INCLUDE=prerc.h
PRECOMPILED_PCH=prerc.pch
PRECOMPILED_OBJ=prerc.obj

INCLUDES=.
C_DEFINES=-DUNICODE -D_UNICODE -D_MT

SOURCES=\
	prerc.c		\
        rcdll.c         \
        charmap.c       \
        error.c         \
        getflags.c      \
        getmsg.c        \
        globals.c       \
        ltoa.c          \
        rcpp.c          \
        p0expr.c        \
        p0gettok.c      \
        p0io.c          \
        p0keys.c        \
        p0macros.c      \
        p0prepro.c      \
        p1sup.c         \
        rcpputil.c      \
        scanner.c       \
        tokens.c        \
        rcunicod.c      \
        rc.c            \
        rcfutil.c       \
        rcl.c           \
        rcmenu.c        \
        rcp.c           \
        rcstring.c      \
        rctg.c          \
        rctp.c          \
        rcutil.c        \
        rcx.c           \
        rcppx.c		\
        rcdll.rc

UMTYPE=windows
UMAPPL=
UMLIBS=
UMRES=
