LIBRARY WS2_32

DESCRIPTION 'MicroNT Windows Sockets 2 (flat BSD over AFD)'

EXPORTS

;
; Ordinals match the canonical wsock32/ws2_32 classic table (NT3.5 through XP).
; BSD functions land at 1-23 in this exact order, resolver at 51-57,
; WSA 1.1 compat at 111-116, __WSAFDIsSet at 151.
; Functions removed from our headless build are simply absent;
; _socket.pyd does not import the WSAAsync* block (101-110) or the
; blocking-hook entries (109-114) so no stubs are needed for those.
;

;   --- BSD socket calls (1-23) ---
    accept          @1
    bind            @2
    closesocket     @3
    connect         @4
    getpeername     @5
    getsockname     @6
    getsockopt      @7
    htonl           @8
    htons           @9
    inet_addr       @10
    inet_ntoa       @11
    ioctlsocket     @12
    listen          @13
    ntohl           @14
    ntohs           @15
    recv            @16
    recvfrom        @17
    select          @18
    send            @19
    sendto          @20
    setsockopt      @21
    shutdown        @22
    socket          @23

;   --- Resolver stubs (51-57; 54=getprotobynumber not imported) ---
    gethostbyaddr   @51
    gethostbyname   @52
    getprotobyname  @53
    getprotobynumber @54
    getservbyname   @55
    getservbyport   @56
    gethostname     @57

;   --- WSA 1.1 startup / error (111-116; 113-114 not imported by _socket.pyd) ---
    WSAGetLastError         @111
    WSASetLastError         @112
    WSAStartup              @115
    WSACleanup              @116

;   --- Misc ---
    __WSAFDIsSet    @151
    WSARecvEx       @1107
