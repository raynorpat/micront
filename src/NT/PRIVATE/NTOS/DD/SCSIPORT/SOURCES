MAJORCOMP=ntos
MINORCOMP=scsi

TARGETNAME=scsiport
TARGETPATH=$(BASEDIR)\public\sdk\lib
TARGETTYPE=EXPORT_DRIVER

INCLUDES=..\..\inc

# MicroNT bring-up: force DBG=1 for scsiport so ScsiDebugPrint is the
# real vsprintf+DbgPrint impl (PORT.C #if DBG block) instead of the
# stub. nvme2k's bring-up trace becomes visible regardless of the
# framework-wide DBG=0. Drop this line once the SCSI stack is solid.
C_DEFINES=$(C_DEFINES) -DDBG=1

SOURCES=init.c \
        port.c \
        internal.c \
        scsiport.rc

DLLDEF=obj\*\scsiport.def

!IF $(386)
NTTARGETFILE0=$(SCSIPORT_TARGET:*=i386)
!ENDIF

!IF $(MIPS)
NTTARGETFILE0=$(SCSIPORT_TARGET:*=mips)
!ENDIF

!IF $(ALPHA)
NTTARGETFILE0=$(SCSIPORT_TARGET:*=alpha)
!ENDIF
