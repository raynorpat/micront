TARGETNAME=rpcdce4
TARGETPATH=$(BASEDIR)\public\sdk\lib
TARGETTYPE=DYNLINK

INCLUDES=.;..\..\mtrt;..\lib

#
# Setup for application developer to set breakpoints with windbg
#

NTDEBUGTYPE=both

DLLBASE=0x10000000

SOURCES=           \
        memory.c   \
        uuid.c     \
        binding.c  \
        inqtext.c  \
        epmgmt.c   \
        svrmgmt.c  \
        clntmgmt.c \
        epmp_c.c   \
        mgmt_c.c   \
        dllinit.c

!ifdef RPC_NT31
RPCTARGETENV=-DRPC_NT31
!endif

!ifdef DOSWIN32RPC
RPCENV=-DDOSWIN32RPC -DWIN32RPC
!else
RPCENV=-DNTENV
!endif

C_DEFINES=$(RPCENV) $(RPCTARGETENV) -Dmgmt_DispatchTable=DispatchTable_mgmt

DLLENTRY=InitializeDll
TARGETLIBS=$(BASEDIR)\public\sdk\lib\*\kernel32.lib \
           $(BASEDIR)\public\sdk\lib\*\rpcrt4.lib

LINKLIBS=$(BASEDIR)\public\sdk\lib\*\rpcndr.lib \
         ..\lib\obj\*\svrmgmt.lib

UMTYPE=console
UMTEST=dceclnt*midluser*dcesvr
UMLIBS=$(BASEDIR)\public\sdk\lib\*\rpcdce4.lib \
       $(BASEDIR)\public\sdk\lib\*\rpcrt4.lib

NTTARGETFILE0=epmp.h

