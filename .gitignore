src/NT/PRIVATE/RPC/RUNTIME/MTRT/mgmt_c.c
src/NT/PRIVATE/RPC/RUNTIME/MTRT/mgmt_s.c
# NDRMEM build copies linklist.cxx from MTRT (per its MAKEFILE.INC).
src/NT/PRIVATE/RPC/NDRMEM/LINKLIST.CXX

