# Original source and patches (large, not ours)
/stuff/

# Wine prefix (generated by createwineprefix.sh)
.wineprefix/

# IDE
.vscode/

# Build artifacts in NT source tree
**/obj/
_objects.mac
# .sys driver outputs (all built from in-tree sources)
*.sys

# Generated files
src/NT/PRIVATE/NTOS/RTL/error.h
src/NT/PRIVATE/NTOS/RTL/UP/error.h
src/NT/PRIVATE/NTOS/RTL/GENERR.EXE
src/NT/PRIVATE/NTOS/RTL/GENERR.obj
src/NT/PRIVATE/NTOS/INIT/bugcodes.rc

# RC temp files (rc.exe leaves these; exactly 5 digits after letter)
RC[a-z][0-9][0-9][0-9][0-9][0-9]
RD[a-z][0-9][0-9][0-9][0-9][0-9]

# Boot stub build artifacts
src/boot/*.o
src/boot/boot.elf

# Build products placed in PUBLIC/SDK/LIB
# (we keep *.lib import libraries tracked but ignore DLL/EXE/EXP outputs)
src/NT/PUBLIC/SDK/LIB/I386/ntoskrnl.lib
src/NT/PUBLIC/SDK/LIB/I386/ntoskrnl.exp
src/NT/PUBLIC/SDK/LIB/I386/hal.lib
src/NT/PUBLIC/SDK/LIB/I386/hal.exp
src/NT/PUBLIC/SDK/LIB/I386/tmp.lib
src/NT/PUBLIC/SDK/LIB/I386/tmp.exp
# ntdll is built from our sources — keep .lib tracked, ignore .dll/.exp
src/NT/PUBLIC/SDK/LIB/I386/ntdll.dll
src/NT/PUBLIC/SDK/LIB/I386/ntdll.exp
# nt.lib (URTL) + smdll.lib (SM/CLIENT) — built from source
src/NT/PUBLIC/SDK/LIB/I386/nt.lib
src/NT/PUBLIC/SDK/LIB/I386/smdll.lib
# kernel32.dll is built from source — keep .lib import lib, ignore outputs
src/NT/PUBLIC/SDK/LIB/I386/kernel32.dll
src/NT/PUBLIC/SDK/LIB/I386/kernel32.exp
# csrsrv.dll + basesrv.dll — built from CSR/SERVER + WINDOWS/BASE/SERVER.
# Unlike kernel32.lib / ntdll.lib / smdll.lib (which are linked against
# by lots of in-tree components so we track the .lib import stubs),
# csrsrv.lib and basesrv.lib are used only by the server DLLs
# themselves at link time and get rebuilt from .def every run — no
# reason to version them.
src/NT/PUBLIC/SDK/LIB/I386/csrsrv.dll
src/NT/PUBLIC/SDK/LIB/I386/csrsrv.exp
src/NT/PUBLIC/SDK/LIB/I386/csrsrv.lib
src/NT/PUBLIC/SDK/LIB/I386/basesrv.dll
src/NT/PUBLIC/SDK/LIB/I386/basesrv.exp
src/NT/PUBLIC/SDK/LIB/I386/basesrv.lib

# GUI-side drivers + their export libs. Like csrsrv/basesrv, these are
# all built from in-tree sources on every run.
src/NT/PUBLIC/SDK/LIB/I386/i8042prt.sys
src/NT/PUBLIC/SDK/LIB/I386/kbdclass.sys
src/NT/PUBLIC/SDK/LIB/I386/mouclass.sys
src/NT/PUBLIC/SDK/LIB/I386/vga.sys
src/NT/PUBLIC/SDK/LIB/I386/videoprt.sys
src/NT/PUBLIC/SDK/LIB/I386/videoprt.lib
src/NT/PUBLIC/SDK/LIB/I386/videoprt.exp

# RPC runtime static libs — built from RPC/NDRLIB and RPC/NDR20.
src/NT/PUBLIC/SDK/LIB/I386/RpcNdrp.lib
src/NT/PUBLIC/SDK/LIB/I386/rpcndr20.lib

# MIDL host-tool bootstrap outputs (built by build.sh sdktools phase).
src/NT/PUBLIC/OAK/BIN/I386/midleb.exe
src/NT/PUBLIC/OAK/BIN/I386/midlyacc.exe
src/NT/PUBLIC/OAK/BIN/I386/midlpg.exe
src/NT/PUBLIC/OAK/BIN/I386/midl.exe
# MIDL20 static libs (intermediate link inputs for midl.exe).
src/NT/PRIVATE/RPC/MIDL20/lib/
# Prebuilt .exe shipped in stuff/ — we bootstrap everything from source,
# so reject any .exe under the MIDL tree (build outputs live elsewhere).
src/NT/PRIVATE/RPC/MIDL20/**/*.exe
src/NT/PRIVATE/RPC/MIDLNEW/**/*.exe
src/NT/PRIVATE/RPC/MIDL20/**/*.EXE
src/NT/PRIVATE/RPC/MIDLNEW/**/*.EXE

# mc.exe-generated message resources. WINERROR.MC is the source;
# winerror.h / winerror.rc / MSG00001.bin are rebuilt each time.
src/NT/PRIVATE/WINDOWS/NLSMSG/winerror.h
src/NT/PRIVATE/WINDOWS/NLSMSG/winerror.rc
src/NT/PRIVATE/WINDOWS/NLSMSG/MSG00001.bin
# Kernel32's MAKEFILE.INC copies the NLSMSG outputs here during build.
src/NT/PRIVATE/WINDOWS/BASE/CLIENT/winerror.rc
src/NT/PRIVATE/WINDOWS/BASE/CLIENT/DAYTONA/MSG00001.bin

# Generated boot disk
src/boot/data/disk.raw
src/boot/data/disk.h

# Generated SYSTEM hive (tools/mkhive.py)
src/boot/data/SYSTEM

# gensrv output (installed into OAK/BIN each build)
src/NT/PUBLIC/OAK/BIN/I386/gensrv.exe

# gensrv-generated files (rebuilt every ntdll build)
src/NT/PRIVATE/NTOS/DLL/DAYTONA/i386/usrstubs.asm
src/NT/PRIVATE/NTOS/DLL/DAYTONA/ntdll.xtr

# Generated sysroot trees
src/ntoskrnl.gdb

# Old HAL (preserved for reference, not built)
src/NT/PRIVATE/NTOS/NTHALS.old/

TODO.md

# QEMU/test artifacts
*.log
*.gdb
