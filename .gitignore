# Debug-pipeline tools rebuilt from in-tree source by build.sh — keep
# the import libraries (IMAGEHLP.LIB) tracked, but the executables and
# runtime DLL are regenerated each build.
#
# CVPACK.EXE + cvpack.err stay TRACKED — they're load-bearing for
# bootstrap.  The original NT 3.5 LINK.EXE auto-invokes CVPACK on
# every CV-debug link (which is every link once --syms is on, even
# when building MKMSG / CVPACK itself), so a clean checkout has to
# already have CVPACK to bootstrap the toolchain phase.  Same
# treatment as the other "load-bearing for bootstrap" binaries
# (CL.EXE, NMAKE.EXE, the import .LIB files).
src/NT/PUBLIC/OAK/BIN/I386/BINPLACE.EXE
src/NT/PUBLIC/OAK/BIN/I386/CVDUMP.EXE
src/NT/PUBLIC/OAK/BIN/I386/DBG2DWF.EXE
src/NT/PUBLIC/OAK/BIN/I386/MKMSG.EXE
src/NT/PUBLIC/OAK/BIN/I386/PDBDUMP.EXE
src/NT/PUBLIC/OAK/BIN/I386/SPLITSYM.EXE
src/NT/PUBLIC/OAK/BIN/I386/IMAGEHLP.DLL

# imagehlp runtime + setargv stub — the .lib import stub stays tracked
# (IMAGEHLP.LIB above), the rest is build output.
src/NT/PUBLIC/SDK/LIB/I386/imagehlp.dll
src/NT/PUBLIC/SDK/LIB/I386/imagehlp.exp
src/NT/PUBLIC/SDK/LIB/I386/setargv.obj

# Per-PE debug sidecars produced by splitsym + dbg2dwf as part of every
