src/NT/PRIVATE/BASE/CRTLIB/LIB/I386/*.lib
src/NT/PRIVATE/BASE/CRTLIB/LIB/I386/*.dll
src/NT/PRIVATE/BASE/CRTLIB/LIB/I386/*.exp
