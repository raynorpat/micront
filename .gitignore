src/NT/PRIVATE/LSA/lsarpc_s.c
src/NT/PRIVATE/LSA/INC/lsarpc_c.h

# mc.exe generates win31evt.h/.rc and MSG00001.bin from
# ADVAPI/WIN31EVT.MC each build.
src/NT/PRIVATE/WINDOWS/BASE/ADVAPI/win31evt.h
src/NT/PRIVATE/WINDOWS/BASE/ADVAPI/win31evt.rc
src/NT/PRIVATE/WINDOWS/BASE/ADVAPI/MSG00001.bin

# NTOS bugcodes — mc compiles NLS/BUGCODES.MC to .h/.rc/.bin; build.sh
