src/NT/PRIVATE/NTOS/NLS/BUGCODES.rc
src/NT/PRIVATE/NTOS/NLS/MSG00001.bin
src/NT/PRIVATE/NTOS/INIT/bugcodes.rc
src/NT/PRIVATE/NTOS/INIT/msg00001.bin

# rpcutil is a 3-file static lib linked into advapi32.
src/NT/PUBLIC/SDK/LIB/I386/rpcutil.lib

# LSA / SAM / NetLogon stack — lsass.exe's security subsystem.
# Follows the kernel32/advapi32 pattern: import .lib tracked, .dll + .exp
# regenerated each build. nlrepl is purely static.
src/NT/PUBLIC/SDK/LIB/I386/nlrepl.lib
src/NT/PUBLIC/SDK/LIB/I386/lsasrv.dll
src/NT/PUBLIC/SDK/LIB/I386/lsasrv.exp
src/NT/PUBLIC/SDK/LIB/I386/lsasrv.lib
src/NT/PUBLIC/SDK/LIB/I386/samsrv.dll
src/NT/PUBLIC/SDK/LIB/I386/samsrv.exp
src/NT/PUBLIC/SDK/LIB/I386/samsrv.lib
src/NT/PUBLIC/SDK/LIB/I386/samlib.dll
src/NT/PUBLIC/SDK/LIB/I386/samlib.exp
src/NT/PUBLIC/SDK/LIB/I386/samlib.lib

# midl-generated LSA/SAM stubs, copied into PRIVATE/INC as central
# include root (NEWSAM/LSA/NLSECUTL all consume them).
src/NT/PRIVATE/INC/lsarpc.h
src/NT/PRIVATE/INC/samrpc.h
src/NT/PRIVATE/INC/samrpc_c.h
# NEWSAM midl stubs.
src/NT/PRIVATE/NEWSAM/samrpc.h
src/NT/PRIVATE/NEWSAM/samrpc_c.h
src/NT/PRIVATE/NEWSAM/samrpc_c.c
src/NT/PRIVATE/NEWSAM/samrpc_s.c
