src/NT/PRIVATE/WINDOWS/SCREG/SC/svcctl_s.c
src/NT/PRIVATE/WINDOWS/SCREG/SC/INC/svcctl.h
src/NT/PRIVATE/EVENTLOG/elf.h
src/NT/PRIVATE/EVENTLOG/elf_c.c
src/NT/PRIVATE/EVENTLOG/elf_s.c
